# Copy this file to .env.claude and fill in real values.
# .env.claude is gitignored — never commit actual secrets.
# Sourced automatically by ./claude.sh before launching Claude Code.

# Plain value:
# SOME_API_TOKEN=xxxxx

# Or resolve it from a password manager's CLI instead of storing it in
# plaintext — adapt to whichever one you use; this runs as a real shell
# command when the file is sourced, so any CLI works, no special-casing
# needed:
# export SOME_API_TOKEN=$(op read "op://vault/item/field")
# export SOME_API_TOKEN=$(bw get password <item-id>)
# export SOME_API_TOKEN=$(pass show some/path)
