# Copie ce fichier en .env.claude et renseigne les vraies valeurs.
# .env.claude est gitignored — ne jamais y commiter de vrais secrets.
# Chargé automatiquement par ./claude.sh avant de lancer Claude Code.

# Valeur en clair :
# SOME_API_TOKEN=xxxxx

# Ou résous-la depuis la CLI d'un gestionnaire de mots de passe plutôt que
# de la stocker en clair — adapte à celui que tu utilises ; ceci s'exécute
# comme une vraie commande shell quand le fichier est source-é, donc
# n'importe quelle CLI fonctionne, pas besoin de cas particulier :
# export SOME_API_TOKEN=$(op read "op://vault/item/field")
# export SOME_API_TOKEN=$(bw get password <item-id>)
# export SOME_API_TOKEN=$(pass show some/path)
